#!/usr/bin/env bash
#MISE description="Run the container locally for development"
set -euo pipefail

PORT="${PORT:-3007}"
NAME="${NAME:-ha}"

docker rm -f "${NAME}" 2>/dev/null || true
docker run -d --name "${NAME}" -p "${PORT}:3000" html-anything:latest

echo "Container '${NAME}' running on http://localhost:${PORT}"
echo "Stop with: ./mise-tasks/stop"
