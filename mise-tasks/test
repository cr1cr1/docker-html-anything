#!/usr/bin/env bash
#MISE description="Build, run, health-check, verify tools, and clean up"
set -euo pipefail

PORT="${PORT:-3007}"
NAME="${NAME:-ha-test}"

echo "=== Building image ==="
docker build -t html-anything:latest .

echo "=== Starting container on host port ${PORT} ==="
docker rm -f "${NAME}" 2>/dev/null || true
docker run -d --name "${NAME}" -p "${PORT}:3000" html-anything:latest

cleanup() {
  echo "=== Cleaning up ==="
  docker stop "${NAME}" >/dev/null 2>&1 || true
  docker rm "${NAME}" >/dev/null 2>&1 || true
}
trap cleanup EXIT

echo "=== Waiting for app on :${PORT} ==="
for i in {1..60}; do
  if curl -sf "http://localhost:${PORT}" >/dev/null; then
    echo "App is responding on :${PORT}"
    break
  fi
  sleep 2
done

echo "=== Verifying mise tools ==="
docker exec "${NAME}" opencode --version
docker exec "${NAME}" pi --version

echo "=== Checking harness startup logs ==="
docker logs "${NAME}" > /tmp/ha-logs.txt 2>&1
grep -q '\[harness\]' /tmp/ha-logs.txt
echo "Harness startup logs present"
echo "=== All checks passed ==="
